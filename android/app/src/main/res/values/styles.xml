<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Android 15+ (target SDK 35+) enables edge-to-edge by default,
             which makes the WebView draw under the status bar and obscure
             the wifi / battery / clock icons. fitsSystemWindows tells the
             root decor view to pad its content below the system bars so
             those icons stay visible. Also set the status bar color to
             match the theme so the bar isn't translucent over zinc. -->
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:statusBarColor">#09090b</item>
        <item name="android:navigationBarColor">#09090b</item>
    </style>


    <!-- Pre-API 31 launch theme. Capacitor's SplashScreen plugin uses the
         legacy code path here, which reads android:windowBackground (not
         android:background — the scaffold default was subtly wrong and the
         splash drawable never actually rendered). API 31+ gets the modern
         SplashScreen API via values-v31/styles.xml, which ignores this. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>